# Copy to .env and fill in. .env is gitignored — never commit it.
# Generate a READ-ONLY key pair in the Trading 212 app (no ordering scope).
# The secret is shown only once at generation time — copy it immediately.
T212_API_KEY=your_key_here
T212_API_SECRET=your_secret_here

# Login gate for the dashboard. Leave DASHBOARD_PASSWORD blank for local-only use
# (no login). Set it before exposing the app anywhere (hosting / tunnel).
DASHBOARD_USER=you
DASHBOARD_PASSWORD=
